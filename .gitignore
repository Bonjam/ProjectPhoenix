# ==========================================
# Project Phoenix
# Git Ignore
# ==========================================

# --------------------------------------------------
# Private configuration
# --------------------------------------------------
config.conf
config.conf.backup.*

# SSH Keys
ssh/
*.pem
*.key
id_ed25519
id_ed25519.pub

# --------------------------------------------------
# Runtime generated files
# --------------------------------------------------
logs/
status/
history/
inventory/
discovery/
manifests/

# Generated reports
reports/
*.html

# Backup output
*.log

# --------------------------------------------------
# Build output
# --------------------------------------------------
build/
dist/

# --------------------------------------------------
# Test output
# --------------------------------------------------
test-output/
test-local/

# --------------------------------------------------
# IDE
# --------------------------------------------------
.vscode/settings.json
.idea/

# --------------------------------------------------
# Operating system files
# --------------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------------
# Temporary files
# --------------------------------------------------
*.tmp
*.bak
*.swp

# --------------------------------------------------
# Python (future proofing)
# --------------------------------------------------
__pycache__/

# --------------------------------------------------
# Environment files
# --------------------------------------------------
.env
.env.local
